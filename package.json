{
  "name": "lasallian-me-api",
  "version": "1.0.0",
  "description": "This project was generated using the `create-lscs-api` scaffolder, based on the official La Salle Computer Society (LSCS) Backend Standards.",
  "main": "dist/server.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node .",
    "prestart": "npm run build",
    "dev": "tsx watch server.ts",
    "build": "tsc && tsc-alias",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "verify:emailer": "tsx src/shared/infrastructure/mailer.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@electric-sql/pglite": "^0.3.16",
    "@types/nodemailer": "^8.0.0",
    "better-auth": "^1.6.9",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-beta.21",
    "drizzle-seed": "1.0.0-beta.21",
    "express": "^5.2.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "1.0.0-beta.21",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^3.2.4"
  }
}
